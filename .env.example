# 环境变量配置示例
# 复制此文件为 .env 并填写实际值

# 飞书配置
FEISHU_APP_ID=your_app_id
FEISHU_APP_SECRET=your_app_secret
FEISHU_USER_ID=your_user_id

# 日志配置
LOG_LEVEL=INFO
LOG_DIR=logs

# 股票配置
STOCK_PUSH_INTERVAL_MINUTES=30
ALERT_THRESHOLD_UP=5.0
ALERT_THRESHOLD_DOWN=-5.0

# Web 配置
FLASK_ENV=development
FLASK_PORT=5000

# 数据库配置（如使用）
# DATABASE_URL=sqlite:///data/stocks.db
